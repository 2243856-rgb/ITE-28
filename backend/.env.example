PORT=4001
NODE_ENV=development
JWT_SECRET=replace-with-a-long-random-secret

# Optional: development only — if unset and NODE_ENV is not "production", the API uses a built-in fallback (not for production).

# Seeded demo users (in-memory): 
#   demo@nestvet.app / password123 (OWNER — pet parent app)
#   admin@nestvet.app / admin123 (ADMIN — clinic console + Account tab sign out)

# --- Azure SQL (optional until you migrate off store.js) ---
# Copy "ADO.NET" connection string from Azure Portal → SQL database → Connection strings.
# Paste as one line. Encrypt=True is required for Azure.
# SQL_CONNECTION_STRING=Server=tcp:YOURSERVER.database.windows.net,1433;Initial Catalog=nestvetdb;User ID=...;Password=...;Encrypt=True;TrustServerCertificate=False;
