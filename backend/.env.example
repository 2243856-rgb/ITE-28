PORT=4001
NODE_ENV=development
JWT_SECRET=replace-with-a-long-random-secret

# Optional: folder with az.cmd if Node cannot find Azure CLI (Entra). Default is prepended on Windows.
# AZURE_CLI_WBIN=C:\Program Files\Microsoft SDKs\Azure\CLI2\wbin

# --- If your SQL server uses "Microsoft Entra ID only" (no SQL password logins) ---
# 1) Install Azure CLI, then: az login   (same account as SQL "Microsoft Entra admin", or an identity with DB access)
# 2) Comment out AZURE_SQL_CONNECTION_STRING. Set:
AZURE_SQL_USE_ENTRA=true
AZURE_SQL_SERVER=nestvetdatabase.database.windows.net
AZURE_SQL_DATABASE=nestvetdb
# When creating appointments, use this clinicId if you have no other clinic (matches DB seed):
# 00000000-0000-4000-8000-000000000001
# Optional user-assigned MI on Azure: AZURE_SQL_ENTRA_CLIENT_ID=<managed-identity-client-id>
# AZURE_SQL_TRUST_CERT=true

# --- Classic SQL username + password (only if Entra-only is OFF on the server) ---
# AZURE_SQL_USE_ENTRA=false
# AZURE_SQL_CONNECTION_STRING=Server=tcp:...;User ID=...;Password=...;Initial Catalog=nestvetdb;Encrypt=True;...
